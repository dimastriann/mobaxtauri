{
  "name": "tauri-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,html,json}\"",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "project:check": "tsc --noEmit && eslint src && prettier --check \"src/**/*.{ts,tsx,css,html,json}\" && cargo clippy --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-stronghold": "^2.3.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "framer-motion": "^12.4.7",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.6.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@chakra-ui/cli": "^3.34.0",
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^26.0.0",
    "lucide-react": "^1.7.0",
    "prettier": "^3.8.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.0.4",
    "vitest": "^3.0.5"
  }
}
